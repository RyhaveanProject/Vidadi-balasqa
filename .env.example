# ============================================================
# Vidadi AI Voice Userbot — Environment Variables
# ============================================================

# --- Telegram credentials ---
# Get API_ID + API_HASH from https://my.telegram.org/apps
API_ID=123456
API_HASH=your_api_hash_here

# Pyrogram v2 session string (generate locally once, then paste here)
SESSION_STRING=your_pyrogram_session_string

# Telegram numeric user id of the Owner (Raven). Use @userinfobot to find it.
OWNER_ID=123456789

# --- Gemini / LLM ---
# Option A: your own Gemini key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Option B: Emergent universal key (works for gemini/openai/anthropic via emergentintegrations)
# If set, takes priority over GEMINI_API_KEY when LLM_PROVIDER=emergent
EMERGENT_LLM_KEY=

# Which LLM backend to use: "gemini" (direct, supports streaming) or "emergent"
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# --- Whisper STT ---
WHISPER_MODEL=base
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=az
WHISPER_CPU_THREADS=2

# --- Edge-TTS ---
# Azerbaijani male voice. Alternatives: az-AZ-BanuNeural (female)
TTS_VOICE=az-AZ-BabekNeural
TTS_RATE=+5%
TTS_PITCH=+0Hz
TTS_MAX_CHARS=600

# --- Personality ---
BOT_NAME=Vidadi

# --- Storage ---
DB_PATH=/app/data/vidadi.db

# --- Behavior tuning ---
CHAT_REPLY_PROBABILITY=0.18
IDLE_CHAT_INTERVAL_SEC=900

# --- Realtime VAD tuning ---
# Aggressiveness 0-3 (3 = strictest, treats more sound as non-speech)
VAD_AGGRESSIVENESS=2
# Minimum speech length to consider it a real utterance (ms)
MIN_SPEECH_MS=300
# How long of silence ends an utterance — lower = snappier reply but more cut-offs
SILENCE_END_MS=500

# --- Full-duplex / interrupt ---
# When true, user speech mid-bot-reply cancels the current playback.
INTERRUPT_ENABLED=true

# --- Safety fallback (ffmpeg loopback) ---
# Used only if no in-process inbound API is available in your PyTgCalls build.
# E.g. "default.monitor" on Linux with PulseAudio.
# LOOPBACK_SOURCE=default.monitor
